{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Work Console",
  "version": "0.1.0",
  "identifier": "dev.jhc.agent-work-console",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Work Console",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Hermes Agent Work Console",
    "longDescription": "Cross-platform console for managing Hermes agent sessions, prompts, and task runs."
  }
}
